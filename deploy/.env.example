# Deployment Environment Configuration
# This file is used by the switch-env scripts to update the .env file.

# Choose environment: "ritual" or "hardhat"
USE_ENV=hardhat

# RPC URLs
RITUAL_RPC_URL=https://ritual.meechain.live
HARDHAT_RPC_URL=http://localhost:8545

# Deployment Settings
DEPLOY_NETWORK=hardhat
DEPLOY_CONTRACT_ADDRESS=
DEPLOY_BLOCK_NUMBER=0
DEPLOY_CLIENT_VERSION=HardhatNetwork
